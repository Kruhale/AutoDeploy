# =====================================================
# AutoDeploy — variables de entorno
# =====================================================
# Copia este archivo a `.env` y rellena los valores reales.
# Nunca subas el archivo `.env` al repositorio (está en .gitignore).
#
#   cp .env.example .env
#   nano .env
#

# ===== Seguridad =====

# Clave para firmar tokens JWT (HMAC-SHA384).
# Debe ser una cadena Base64 de al menos 256 bits.
# Generala con: openssl rand -base64 48
AUTODEPLOY_JWT_SECRET=cambiar-por-secreto-base64-fuerte

# Clave AES-256 con la que se cifran las credenciales SSH de los servidores
# (passwords y claves privadas) antes de guardarlas en MongoDB.
# Debe ser una cadena Base64 de exactamente 32 bytes decodificada.
# Generala con: openssl rand -base64 32
AUTODEPLOY_CIFRADO_CLAVE=cambiar-por-clave-aes-base64

# ===== Asistente IA (OpenRouter) =====

# API key de OpenRouter (https://openrouter.ai/keys). Opcional: si no se
# define, el asistente IA mostrará un error al primer mensaje.
OPENROUTER_API_KEY=sk-or-v1-tu-clave-aqui

# Modelo por defecto para el asistente IA. Cualquier slug válido de
# https://openrouter.ai/models. Recomendado: openai/gpt-4o-mini (barato y
# fiable). Los modelos `:free` tienen rate limits estrictos.
OPENROUTER_MODEL=openai/gpt-4o-mini

# ===== Sandbox SSH (servicio sandbox-ssh del docker-compose) =====

# Clave pública SSH que se instalará en /home/demo/.ssh/authorized_keys del
# contenedor sandbox-ssh. Solo se acepta autenticación por clave (sin password).
# El SSH del contenedor escucha en 2222 y se publica en el puerto 2222 del host,
# así que desde la app se configura como: host = dominio del VPS, puerto = 2222,
# usuario = demo, clave privada = la pareja de esta pública.
# Generala con: ssh-keygen -t ed25519 -f ~/.ssh/id_ed25519_autodeploy_sandbox -N ""
SANDBOX_PUBLIC_KEY=ssh-ed25519 AAAA... autodeploy-sandbox-demo

# ===== Puerto del host (VPS) =====

# Puerto del host donde se publica el frontend nginx del contenedor.
# El nginx del HOST del VPS hace proxy_pass desde el dominio público a este puerto.
# Por defecto 8082. Cambiar si está ocupado por otra app del VPS.
HOST_PORT=8082

# ===== CI/CD (solo necesario para CD desde GitHub Actions) =====

# Tag de imagen Docker a desplegar. Por defecto `latest` (última build de main).
# Cambiar a un SHA concreto para hacer rollback.
IMAGE_TAG=latest
